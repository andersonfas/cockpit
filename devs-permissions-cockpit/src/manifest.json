{
    "version": 0,
    "require": {
        "cockpit": "264"
    },
    "bridges": [
        {
            "match": { "superuser": "require" },
            "spawn": ["/usr/libexec/devs-permissions/cockpit-helper.sh"],
            "environ": ["LANG"]
        }
    ],
    "menu": {
        "index": {
            "label": "DevOps Permissions",
            "order": 85,
            "superuser": "require",
            "keywords": [
                {
                    "matches": ["devs", "permissions", "docker", "developers", "access", "teams", "exec", "webconf", "audit"]
                }
            ]
        }
    },
    "content-security-policy": "default-src 'self'; style-src 'self'; script-src 'self'; img-src 'self' data:"
}
